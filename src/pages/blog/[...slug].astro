---
import { getCollection } from 'astro:content';
import BlogLayout from '../../layouts/BlogLayout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({
    params: { slug: post.slug },
    props: { post, allPosts: posts },
  }));
}

const { post, allPosts } = Astro.props;
const { Content, headings } = await post.render();

const related = allPosts
  .filter(p => p.slug !== post.slug && p.data.category === post.data.category)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

// Navigation prev/next dans l'ordre chronologique (plus récents → plus anciens)
const sortedAll = allPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const idx = sortedAll.findIndex(p => p.slug === post.slug);
const newer = idx > 0 ? sortedAll[idx - 1] : null;
const older = idx < sortedAll.length - 1 ? sortedAll[idx + 1] : null;
---

<BlogLayout post={post} headings={headings} related={related} newer={newer} older={older}>
  <Content />
</BlogLayout>
