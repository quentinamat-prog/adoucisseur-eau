---
import type { IconName } from './icons';

interface Props {
  name: IconName;
  class?: string;
  size?: number | string;
  strokeWidth?: number;
  fill?: boolean;
}
const {
  name,
  class: className = '',
  size = 24,
  strokeWidth = 1.75,
  fill = false,
} = Astro.props;
---

<svg
  width={size}
  height={size}
  viewBox="0 0 24 24"
  fill={fill ? 'currentColor' : 'none'}
  stroke="currentColor"
  stroke-width={strokeWidth}
  stroke-linecap="round"
  stroke-linejoin="round"
  class={className}
  aria-hidden="true"
>
  {name === 'chef-hat' && (
    <>
      <path d="M6 13.5c-1.7 0-3-1.5-3-3.5 0-1.8 1.4-3.3 3.2-3.5.4-2 2.3-3.5 4.8-3.5s4.4 1.5 4.8 3.5c1.8.2 3.2 1.7 3.2 3.5 0 2-1.3 3.5-3 3.5" />
      <path d="M6 13.5V19a2 2 0 0 0 2 2h8a2 2 0 0 0 2-2v-5.5" />
      <line x1="6" y1="16.5" x2="18" y2="16.5" />
    </>
  )}

  {name === 'calendar' && (
    <>
      <rect x="3" y="5" width="18" height="16" rx="2.5" />
      <line x1="3" y1="10" x2="21" y2="10" />
      <line x1="8" y1="3" x2="8" y2="7" />
      <line x1="16" y1="3" x2="16" y2="7" />
      <circle cx="8" cy="14.5" r="0.9" fill="currentColor" stroke="none" />
      <circle cx="12" cy="14.5" r="0.9" fill="currentColor" stroke="none" />
      <circle cx="16" cy="14.5" r="0.9" fill="currentColor" stroke="none" />
    </>
  )}

  {name === 'chat' && (
    <>
      <path d="M21 15.5a2 2 0 0 1-2 2H8.5L4 21.5v-14a2 2 0 0 1 2-2h13a2 2 0 0 1 2 2z" />
      <circle cx="9" cy="11" r="0.9" fill="currentColor" stroke="none" />
      <circle cx="12.5" cy="11" r="0.9" fill="currentColor" stroke="none" />
      <circle cx="16" cy="11" r="0.9" fill="currentColor" stroke="none" />
    </>
  )}

  {name === 'heart' && (
    <path d="M12 20.5s-7.5-4.7-7.5-10.2a4.3 4.3 0 0 1 7.5-2.9 4.3 4.3 0 0 1 7.5 2.9c0 5.5-7.5 10.2-7.5 10.2z" />
  )}

  {name === 'star' && (
    <path d="M12 2.5l2.9 6.1 6.6.9-4.8 4.6 1.2 6.6-5.9-3.3-5.9 3.3 1.2-6.6L2.5 9.5l6.6-.9z" />
  )}

  {name === 'leaf' && (
    <>
      <path d="M19.5 4.5c-.8 7.5-5 12-12 12.5-.2-3.5 1.8-8.2 4.8-10.8 2.2-1.9 4.8-2.1 7.2-1.7z" />
      <path d="M4 20c2-5 4.5-9 10-12" />
    </>
  )}

  {name === 'location' && (
    <>
      <path d="M12 21.5s-7-6.3-7-12a7 7 0 0 1 14 0c0 5.7-7 12-7 12z" />
      <circle cx="12" cy="9.5" r="2.5" />
    </>
  )}

  {name === 'fork-knife' && (
    <>
      <path d="M7 3v8a2 2 0 0 1-2 2v8" />
      <path d="M7 3v8a2 2 0 0 0 2 2v8" />
      <line x1="7" y1="3" x2="7" y2="8" />
      <path d="M17 3c-2 0-3 2-3 5s1 5 3 5v8" />
      <line x1="17" y1="3" x2="17" y2="13" />
    </>
  )}

  {name === 'bowl' && (
    <>
      <path d="M3 11h18" />
      <path d="M4.5 11a7.5 7.5 0 0 0 15 0" />
      <path d="M8 4c.5 1.5-.3 2.5-.8 3.5" />
      <path d="M12 3c.5 1.5-.3 2.5-.8 3.5" />
      <path d="M16 4c.5 1.5-.3 2.5-.8 3.5" />
      <line x1="3" y1="20" x2="21" y2="20" />
    </>
  )}

  {name === 'sushi' && (
    <>
      <ellipse cx="12" cy="12" rx="9" ry="5" />
      <ellipse cx="12" cy="12" rx="3.5" ry="2.5" />
      <path d="M3 12c0-.5.2-1 .4-1.4" />
      <path d="M20.6 13.4c.2-.4.4-.9.4-1.4" />
    </>
  )}

  {name === 'croissant' && (
    <>
      <path d="M3.5 14c-.5-5 3-9.5 8-10 1 3-1 7-4 9s-4 1-4 1z" />
      <path d="M20.5 14c.5-5-3-9.5-8-10-1 3 1 7 4 9s4 1 4 1z" />
      <path d="M3.5 14c3 1.5 5.5 4 8.5 4s5.5-2.5 8.5-4" />
    </>
  )}

  {name === 'pot' && (
    <>
      <path d="M4 10h16v6a4 4 0 0 1-4 4H8a4 4 0 0 1-4-4z" />
      <line x1="3" y1="10" x2="21" y2="10" />
      <path d="M2 10h2" />
      <path d="M20 10h2" />
      <path d="M9 5c0-1.5 1-2.5 3-2.5s3 1 3 2.5c0 1-.5 1.5-1 2" />
      <path d="M11 7c-.5.5-1 1.5-1 3" />
    </>
  )}

  {name === 'wine' && (
    <>
      <path d="M8 3h8c0 4-1 8-4 8s-4-4-4-8z" />
      <line x1="12" y1="11" x2="12" y2="20" />
      <line x1="8" y1="20" x2="16" y2="20" />
    </>
  )}

  {name === 'cake' && (
    <>
      <path d="M4 12v8a1 1 0 0 0 1 1h14a1 1 0 0 0 1-1v-8" />
      <path d="M3 12a2 2 0 0 0 2 2c1 0 1.5-.5 2-1 .5.5 1 1 2 1s1.5-.5 2-1c.5.5 1 1 2 1s1.5-.5 2-1c.5.5 1 1 2 1a2 2 0 0 0 2-2V9a1 1 0 0 0-1-1H4a1 1 0 0 0-1 1z" />
      <line x1="12" y1="2" x2="12" y2="8" />
      <circle cx="12" cy="2.5" r="0.8" fill="currentColor" stroke="none" />
    </>
  )}

  {name === 'shrimp' && (
    <>
      <path d="M4 12c0-4.5 4-8 9-8 3 0 5 1 5 3s-2 2-4 2c-3 0-5 1-5 3.5 0 3 3 5.5 7 5.5" />
      <circle cx="16" cy="6" r="0.8" fill="currentColor" stroke="none" />
      <path d="M14 20l-2-2" />
    </>
  )}

  {name === 'steak' && (
    <>
      <path d="M12 3c5 0 9 3.5 9 8s-3 10-9 10-9-5.5-9-10 4-8 9-8z" />
      <path d="M9 9c0 2 1.5 3.5 3.5 3.5S16 11 16 9" />
    </>
  )}

  {name === 'pen' && (
    <>
      <path d="M17 3l4 4-12 12H5v-4z" />
      <line x1="14" y1="6" x2="18" y2="10" />
    </>
  )}

  {name === 'sparkle' && (
    <>
      <path d="M12 3l1.8 5.2L19 10l-5.2 1.8L12 17l-1.8-5.2L5 10l5.2-1.8z" />
      <path d="M19 15l.9 2.1L22 18l-2.1.9L19 21l-.9-2.1L16 18l2.1-.9z" />
    </>
  )}

  {name === 'arrow-right' && (
    <>
      <line x1="5" y1="12" x2="19" y2="12" />
      <polyline points="12,5 19,12 12,19" />
    </>
  )}

  {name === 'bell' && (
    <>
      <path d="M6 9a6 6 0 0 1 12 0c0 7 3 8 3 8H3s3-1 3-8" />
      <path d="M10.3 21a1.94 1.94 0 0 0 3.4 0" />
    </>
  )}

  {name === 'lock' && (
    <>
      <rect x="4" y="11" width="16" height="10" rx="2" />
      <path d="M8 11V7a4 4 0 0 1 8 0v4" />
    </>
  )}

  {name === 'shield-check' && (
    <>
      <path d="M12 21s8-4 8-10V5l-8-2-8 2v6c0 6 8 10 8 10z" />
      <polyline points="9,12 11,14 15,10" />
    </>
  )}

  {name === 'check' && (
    <polyline points="4,12 10,18 20,6" />
  )}
</svg>
