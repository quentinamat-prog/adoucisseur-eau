---
import type { MarkdownHeading } from 'astro';
import Icon from './Icon.astro';
import siteConfig from '../../site.config.mjs';

interface Props {
  headings: MarkdownHeading[];
}
const { headings } = Astro.props;
const toc = headings.filter((h) => h.depth === 2);
---

<!-- ── Desktop sidebar (lg+) ── -->
<aside class="hidden lg:block lg:sticky lg:top-24 lg:self-start space-y-6">

  {toc.length > 0 && (
    <nav class="bg-white rounded-2xl p-6 shadow-sm border border-beige" aria-label="Sommaire">
      <p class="font-body text-xs font-bold uppercase tracking-widest text-dark/50 mb-4">Sommaire</p>
      <ul class="space-y-1">
        {toc.map((h) => (
          <li>
            <a
              href={`#${h.slug}`}
              data-toc-link={h.slug}
              class="toc-link block font-body text-sm text-dark/70 hover:text-terracotta transition-colors leading-snug py-1.5 border-l-2 border-transparent pl-3 truncate"
              title={h.text}
            >
              {h.text}
            </a>
          </li>
        ))}
      </ul>
    </nav>
  )}

  <!-- CTA -->
  <div class="bg-teal rounded-2xl p-6 overflow-hidden relative">
    <div class="absolute -top-2 -right-2 text-cream/10">
      <Icon name="chef-hat" size={100} strokeWidth={1} />
    </div>
    <div class="relative">
      <span class="tag tag-terracotta mb-3">Prêt à savourer ?</span>
      <h3 class="font-display text-xl text-cream leading-tight mt-3 mb-3">
        Votre chef privé,<br />
        <span class="font-script text-beige text-2xl">à portée de main</span>
      </h3>
      <p class="font-body text-xs text-cream/70 leading-relaxed mb-5">
        Découvrez des centaines de chefs près de chez vous et réservez en quelques clics.
      </p>
      <div class="space-y-2">
        <a href="/#download" class="flex items-center gap-2 bg-dark text-cream px-3 py-2 rounded-xl font-body transition-all hover:bg-dark/80" aria-label="App Store">
          <svg class="w-5 h-5 fill-cream flex-shrink-0" viewBox="0 0 24 24"><path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/></svg>
          <div class="leading-tight"><div class="text-[10px] text-cream/60">Télécharger sur</div><div class="text-xs font-semibold">App Store</div></div>
        </a>
        <a href="/#download" class="flex items-center gap-2 bg-dark text-cream px-3 py-2 rounded-xl font-body transition-all hover:bg-dark/80" aria-label="Google Play">
          <svg class="w-5 h-5 flex-shrink-0" viewBox="0 0 24 24"><path fill="#00C4FF" d="M3.5 1.8L13.5 12 3.5 22.2C3.2 22 3 21.6 3 21.2V2.8c0-.4.2-.8.5-1z"/><path fill="#FFBC00" d="M17.5 8.5l2.3 1.3L17.5 12l2.3 2.2-2.3 1.3-4-3.5z"/><path fill="#F44336" d="M13.5 12l4 3.5-10.3 5.9c-.3.2-.7.2-1 0L13.5 12z"/><path fill="#4CAF50" d="M13.5 12L6.2 2.6c.3-.2.7-.2 1 0l10.3 5.9-4 3.5z"/></svg>
          <div class="leading-tight"><div class="text-[10px] text-cream/60">Télécharger sur</div><div class="text-xs font-semibold">Google Play</div></div>
        </a>
      </div>
    </div>
  </div>

  <!-- Share -->
  <div class="bg-white rounded-2xl p-6 shadow-sm border border-beige">
    <p class="font-body text-xs font-bold uppercase tracking-widest text-dark/50 mb-4">Partager</p>
    <div class="flex gap-2">
      <button data-share="twitter" aria-label="Partager sur X" class="share-btn w-9 h-9 rounded-full bg-beige hover:bg-terracotta hover:text-cream text-dark/60 flex items-center justify-center transition-colors">
        <svg class="w-4 h-4 fill-current" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
      </button>
      <button data-share="facebook" aria-label="Partager sur Facebook" class="share-btn w-9 h-9 rounded-full bg-beige hover:bg-terracotta hover:text-cream text-dark/60 flex items-center justify-center transition-colors">
        <svg class="w-4 h-4 fill-current" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
      </button>
      <button data-share="copy" aria-label="Copier le lien" class="share-btn w-9 h-9 rounded-full bg-beige hover:bg-terracotta hover:text-cream text-dark/60 flex items-center justify-center transition-colors">
        <svg class="w-4 h-4 fill-none stroke-current" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13.19 8.688a4.5 4.5 0 011.242 7.244l-4.5 4.5a4.5 4.5 0 01-6.364-6.364l1.757-1.757m13.35-.622l1.757-1.757a4.5 4.5 0 00-6.364-6.364l-4.5 4.5a4.5 4.5 0 001.242 7.244"/></svg>
      </button>
    </div>
  </div>
</aside>


<!-- ── Mobile FAB (< lg) ── -->
{toc.length > 0 && (
  <div class="lg:hidden">

    <!-- FAB button -->
    <button
      id="toc-fab"
      aria-label="Plan de l'article"
      aria-expanded="false"
      aria-controls="toc-sheet"
      class="fixed bottom-6 left-1/2 -translate-x-1/2 z-40
             flex items-center gap-2
             bg-teal text-cream
             pl-4 pr-5 py-3
             rounded-full shadow-xl
             font-body text-sm font-semibold
             transition-all duration-200
             hover:bg-teal/90 active:scale-95"
    >
      <!-- Animated hamburger / close icon -->
      <span id="fab-icon" class="relative w-5 h-5 flex-shrink-0">
        <svg class="fab-lines absolute inset-0 transition-all duration-200" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" viewBox="0 0 20 20">
          <line x1="3" y1="6" x2="17" y2="6" />
          <line x1="3" y1="10" x2="12" y2="10" />
          <line x1="3" y1="14" x2="17" y2="14" />
        </svg>
        <svg class="fab-close absolute inset-0 transition-all duration-200 opacity-0 scale-75" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" viewBox="0 0 20 20">
          <line x1="4" y1="4" x2="16" y2="16" />
          <line x1="16" y1="4" x2="4" y2="16" />
        </svg>
      </span>
      <span id="fab-label">Plan de l'article</span>
      <span class="ml-1 bg-cream/20 text-cream text-xs px-1.5 py-0.5 rounded-full font-bold">
        {toc.length}
      </span>
    </button>

    <!-- Backdrop -->
    <div
      id="toc-backdrop"
      class="fixed inset-0 z-40 bg-dark/50 backdrop-blur-sm
             opacity-0 pointer-events-none
             transition-opacity duration-300 ease-out"
    ></div>

    <!-- Bottom sheet -->
    <div
      id="toc-sheet"
      role="dialog"
      aria-modal="true"
      aria-label="Plan de l'article"
      class="fixed inset-x-0 bottom-0 z-50
             bg-cream rounded-t-3xl shadow-2xl
             translate-y-full
             transition-transform duration-350 ease-[cubic-bezier(0.32,0.72,0,1)]
             max-h-[75vh] flex flex-col"
    >
      <!-- Handle -->
      <div class="flex justify-center pt-3 pb-1 flex-shrink-0">
        <div class="w-10 h-1 rounded-full bg-dark/20"></div>
      </div>

      <!-- Header -->
      <div class="flex items-center justify-between px-6 pt-2 pb-4 flex-shrink-0 border-b border-beige">
        <div class="flex items-center gap-2">
          <div class="w-7 h-7 rounded-lg bg-teal/10 text-teal flex items-center justify-center">
            <svg fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" viewBox="0 0 20 20" class="w-4 h-4">
              <line x1="3" y1="5" x2="17" y2="5" />
              <line x1="3" y1="9" x2="12" y2="9" />
              <line x1="3" y1="13" x2="17" y2="13" />
            </svg>
          </div>
          <span class="font-body font-bold text-dark text-sm">Plan de l'article</span>
        </div>
        <button id="toc-close" aria-label="Fermer" class="w-8 h-8 rounded-full bg-beige flex items-center justify-center text-dark/60 hover:bg-terracotta hover:text-cream transition-colors">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" viewBox="0 0 16 16">
            <line x1="3" y1="3" x2="13" y2="13" /><line x1="13" y1="3" x2="3" y2="13" />
          </svg>
        </button>
      </div>

      <!-- TOC list (scrollable) -->
      <nav class="overflow-y-auto flex-1 px-6 py-4">
        <ul class="space-y-1">
          {toc.map((h, i) => (
            <li>
              <a
                href={`#${h.slug}`}
                data-toc-link={h.slug}
                data-mobile-toc
                class="toc-link flex items-center gap-3 font-body text-sm text-dark/70 py-3 border-b border-beige/60 last:border-0 active:text-terracotta"
              >
                <span class="flex-shrink-0 w-6 h-6 rounded-full bg-beige text-teal font-bold text-xs flex items-center justify-center">
                  {i + 1}
                </span>
                <span>{h.text}</span>
              </a>
            </li>
          ))}
        </ul>
      </nav>

      <!-- Sheet footer: CTA + share -->
      <div class="px-6 py-4 flex-shrink-0 border-t border-beige bg-cream rounded-t-none">
        <a href="/#download" class="flex items-center justify-center gap-2 bg-teal text-cream py-3 rounded-xl font-body font-semibold text-sm w-full mb-3 hover:bg-teal/90 transition-colors">
          <Icon name="chef-hat" size={18} strokeWidth={1.75} />
          {siteConfig.article.cta}
        </a>
        <div class="flex justify-center gap-3">
          <button data-share="twitter" aria-label="X" class="share-btn w-9 h-9 rounded-full bg-beige text-dark/60 hover:bg-terracotta hover:text-cream flex items-center justify-center transition-colors">
            <svg class="w-4 h-4 fill-current" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
          </button>
          <button data-share="facebook" aria-label="Facebook" class="share-btn w-9 h-9 rounded-full bg-beige text-dark/60 hover:bg-terracotta hover:text-cream flex items-center justify-center transition-colors">
            <svg class="w-4 h-4 fill-current" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
          </button>
          <button data-share="copy" aria-label="Copier le lien" class="share-btn w-9 h-9 rounded-full bg-beige text-dark/60 hover:bg-terracotta hover:text-cream flex items-center justify-center transition-colors">
            <svg class="w-4 h-4 fill-none stroke-current" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13.19 8.688a4.5 4.5 0 011.242 7.244l-4.5 4.5a4.5 4.5 0 01-6.364-6.364l1.757-1.757m13.35-.622l1.757-1.757a4.5 4.5 0 00-6.364-6.364l-4.5 4.5a4.5 4.5 0 001.242 7.244"/></svg>
          </button>
        </div>
      </div>
    </div>
  </div>
)}

<style>
  #toc-sheet { transition-duration: 350ms; }
  #toc-sheet.open { transform: translateY(0); }
  #toc-backdrop.open { opacity: 1; pointer-events: auto; }

  /* FAB open state icon swap */
  #toc-fab.open .fab-lines { opacity: 0; transform: scale(0.75); }
  #toc-fab.open .fab-close { opacity: 1; transform: scale(1); }
</style>

<script>
  // ── Intersection Observer for active TOC link (desktop + mobile) ──
  const tocLinks = document.querySelectorAll<HTMLAnchorElement>('[data-toc-link]');
  const sections = Array.from(tocLinks).reduce<HTMLElement[]>((acc, link) => {
    const id = link.dataset.tocLink;
    const el = id ? document.getElementById(id) : null;
    if (el && !acc.includes(el)) acc.push(el);
    return acc;
  }, []);

  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (!entry.isIntersecting) return;
      const id = entry.target.id;
      tocLinks.forEach(link => {
        const active = link.dataset.tocLink === id;
        link.classList.toggle('text-terracotta', active);
        link.classList.toggle('border-terracotta', active);
        link.classList.toggle('font-semibold', active);
        link.classList.toggle('text-dark/70', !active);
        link.classList.toggle('border-transparent', !active);
      });
    });
  }, { rootMargin: '-80px 0px -60% 0px' });

  sections.forEach(el => observer.observe(el));

  // ── Mobile bottom sheet ──
  const fab     = document.getElementById('toc-fab');
  const sheet   = document.getElementById('toc-sheet');
  const backdrop = document.getElementById('toc-backdrop');
  const closeBtn = document.getElementById('toc-close');

  function openSheet() {
    sheet?.classList.add('open');
    backdrop?.classList.add('open');
    fab?.classList.add('open');
    fab?.setAttribute('aria-expanded', 'true');
    document.body.style.overflow = 'hidden';
  }

  function closeSheet() {
    sheet?.classList.remove('open');
    backdrop?.classList.remove('open');
    fab?.classList.remove('open');
    fab?.setAttribute('aria-expanded', 'false');
    document.body.style.overflow = '';
  }

  fab?.addEventListener('click', () => {
    sheet?.classList.contains('open') ? closeSheet() : openSheet();
  });

  backdrop?.addEventListener('click', closeSheet);
  closeBtn?.addEventListener('click', closeSheet);

  // Close sheet when a TOC link is clicked
  document.querySelectorAll('[data-mobile-toc]').forEach(link => {
    link.addEventListener('click', () => setTimeout(closeSheet, 120));
  });

  // Swipe down to close
  let touchStartY = 0;
  sheet?.addEventListener('touchstart', (e) => { touchStartY = e.touches[0].clientY; }, { passive: true });
  sheet?.addEventListener('touchend', (e) => {
    if (e.changedTouches[0].clientY - touchStartY > 60) closeSheet();
  }, { passive: true });

  // ESC key
  document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeSheet(); });

  // ── Share buttons ──
  document.querySelectorAll<HTMLButtonElement>('[data-share]').forEach(btn => {
    btn.addEventListener('click', async () => {
      const url = window.location.href;
      const title = document.title;
      const type = btn.dataset.share;
      if (type === 'twitter') {
        window.open(`https://twitter.com/intent/tweet?url=${encodeURIComponent(url)}&text=${encodeURIComponent(title)}`, '_blank');
      } else if (type === 'facebook') {
        window.open(`https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(url)}`, '_blank');
      } else if (type === 'copy') {
        await navigator.clipboard.writeText(url);
        btn.classList.add('!bg-terracotta', '!text-cream');
        setTimeout(() => btn.classList.remove('!bg-terracotta', '!text-cream'), 1500);
      }
    });
  });
</script>
