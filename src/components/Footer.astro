---
import siteConfig from '../../site.config.mjs';
const currentYear = new Date().getFullYear();
---

<footer class="bg-dark text-cream/60 pt-16 pb-8">
  <div class="max-w-6xl mx-auto px-6">
    <div class="grid md:grid-cols-3 gap-10 pb-12 border-b border-white/10">
      <!-- Brand -->
      <div class="md:col-span-1">
        <a href="/" class="font-display font-bold text-2xl text-cream">
          {siteConfig.logoPrefix}<span class="text-terracotta">{siteConfig.logoSuffix}</span>
        </a>
        <p class="font-body text-sm leading-relaxed mt-4 max-w-xs">
          Guides et conseils indépendants pour choisir, installer et entretenir votre adoucisseur d'eau.
        </p>
      </div>

      <!-- Catégories -->
      <div>
        <h3 class="font-body text-sm font-bold text-cream uppercase tracking-widest mb-5">Thématiques</h3>
        <ul class="space-y-3 font-body text-sm">
          {siteConfig.categories.map((cat: string) => (
            <li>
              <a href={`/blog/categorie/${cat.toLowerCase().normalize('NFD').replace(/[̀-ͯ]/g, '').replace(/['']/g, '').replace(/\s+/g, '-')}`} class="hover:text-cream transition-colors">
                {cat}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Liens utiles -->
      <div>
        <h3 class="font-body text-sm font-bold text-cream uppercase tracking-widest mb-5">Le site</h3>
        <ul class="space-y-3 font-body text-sm">
          <li><a href="/" class="hover:text-cream transition-colors">Accueil</a></li>
          <li><a href="/blog" class="hover:text-cream transition-colors">Tous les articles</a></li>
          <li><a href="/rss.xml" class="hover:text-cream transition-colors">Flux RSS</a></li>
        </ul>
      </div>
    </div>

    <div class="pt-8 flex flex-col md:flex-row items-center justify-between gap-4 font-body text-xs">
      <p>© {currentYear} {siteConfig.name}. Tous droits réservés.</p>
      <p>Site indépendant — Informations à titre indicatif uniquement</p>
    </div>
  </div>
</footer>
