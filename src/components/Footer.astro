---
import Icon from './Icon.astro';
const currentYear = new Date().getFullYear();
---

<footer class="bg-dark text-cream/60 pt-16 pb-8">
  <div class="max-w-6xl mx-auto px-6">
    <div class="grid md:grid-cols-4 gap-10 pb-12 border-b border-white/10">
      <!-- Brand -->
      <div class="md:col-span-2">
        <a href="/" class="font-display text-3xl text-cream">
          Gusti<span class="text-terracotta">chef</span>
        </a>
        <p class="font-body text-sm leading-relaxed mt-4 max-w-xs">
          La plateforme qui connecte particuliers et chefs privés pour des expériences culinaires uniques à domicile.
        </p>
        <div class="flex gap-4 mt-6">
          <a href="#" aria-label="Instagram" class="w-9 h-9 rounded-full bg-white/10 flex items-center justify-center hover:bg-terracotta transition-colors">
            <svg class="w-4 h-4 fill-current" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
          </a>
          <a href="#" aria-label="TikTok" class="w-9 h-9 rounded-full bg-white/10 flex items-center justify-center hover:bg-terracotta transition-colors">
            <svg class="w-4 h-4 fill-current" viewBox="0 0 24 24"><path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1V9.01a6.33 6.33 0 00-.79-.05 6.34 6.34 0 00-6.34 6.34 6.34 6.34 0 006.34 6.34 6.34 6.34 0 006.33-6.34V8.69a8.18 8.18 0 004.78 1.52V6.77a4.84 4.84 0 01-1.01-.08z"/></svg>
          </a>
        </div>
      </div>

      <!-- Links -->
      <div>
        <h3 class="font-body text-sm font-bold text-cream uppercase tracking-widest mb-5">Produit</h3>
        <ul class="space-y-3 font-body text-sm">
          <li><a href="/#features" class="hover:text-cream transition-colors">Fonctionnalités</a></li>
          <li><a href="/#chefs" class="hover:text-cream transition-colors">Pour les chefs</a></li>
          <li><a href="/#particuliers" class="hover:text-cream transition-colors">Pour les particuliers</a></li>
          <li><a href="/#download" class="hover:text-cream transition-colors">Télécharger</a></li>
        </ul>
      </div>

      <div>
        <h3 class="font-body text-sm font-bold text-cream uppercase tracking-widest mb-5">Ressources</h3>
        <ul class="space-y-3 font-body text-sm">
          <li><a href="/blog" class="hover:text-cream transition-colors">Blog</a></li>
          <li><a href="#" class="hover:text-cream transition-colors">Centre d'aide</a></li>
          <li><a href="#" class="hover:text-cream transition-colors">Conditions d'utilisation</a></li>
          <li><a href="#" class="hover:text-cream transition-colors">Politique de confidentialité</a></li>
        </ul>
      </div>
    </div>

    <div class="pt-8 flex flex-col md:flex-row items-center justify-between gap-4 font-body text-xs">
      <p>© {currentYear} Gustichef. Tous droits réservés.</p>
      <p class="inline-flex items-center gap-1.5">Fait avec <Icon name="heart" size={14} fill class="text-terracotta" /> en France</p>
    </div>
  </div>
</footer>
