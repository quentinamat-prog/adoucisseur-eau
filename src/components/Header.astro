---
import siteConfig from '../../site.config.mjs';

interface Props {
  transparent?: boolean;
  activePage?: 'home' | 'blog';
}
const { transparent = false, activePage } = Astro.props;
---

<header
  id="site-header"
  data-transparent={transparent ? "true" : "false"}
  class:list={[
    "fixed top-0 left-0 right-0 z-50 transition-all duration-300",
    transparent ? "bg-transparent" : "bg-cream/90 backdrop-blur-sm border-b border-beige shadow-sm",
  ]}
>
  <div class="max-w-6xl mx-auto px-6 py-4 flex items-center justify-between">
    <a href="/" class="logo font-display font-bold text-xl" aria-label={`${siteConfig.name} – accueil`}>
      <span class="logo-primary">{siteConfig.logoPrefix}</span><span class="text-terracotta">{siteConfig.logoSuffix}</span>
    </a>

    <!-- Desktop nav -->
    <nav class="hidden md:flex items-center gap-8 font-body text-sm font-medium">
      <a
        href="/"
        class:list={["nav-link transition-colors", activePage === 'home' && "nav-active"]}
      >
        Accueil
      </a>
      <a
        href="/blog"
        class:list={["nav-link transition-colors", activePage === 'blog' && "nav-active"]}
      >
        Blog
      </a>
      <a href="/blog/adoucisseur-deau-un-confort-discret-qui-change-tout" class="btn-primary text-xs px-5 py-2.5">
        Guide débutant
      </a>
      <a
        href="https://aqua2000.fr/estimer-votre-besoin?utm_source=blog&utm_medium=https://www.adoucisseur-eau.fr/&utm_campaign=backlinks"
        target="_blank"
        rel="noopener noreferrer"
        class="text-xs px-5 py-2.5 rounded-full font-semibold bg-terracotta text-white hover:opacity-90 transition-opacity whitespace-nowrap"
      >
        Devis gratuit
      </a>
    </nav>

    <!-- Mobile menu button -->
    <button
      id="menu-btn"
      class="md:hidden p-2 rounded-lg menu-icon"
      aria-label="Menu"
      aria-expanded="false"
    >
      <svg id="icon-menu" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
      <svg id="icon-close" class="w-6 h-6 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
  </div>

  <!-- Mobile nav -->
  <nav
    id="mobile-nav"
    class="hidden md:hidden bg-cream border-t border-beige px-6 py-4 flex-col gap-4 font-body text-sm font-medium"
  >
    <a href="/" class="block py-2 text-dark/70 hover:text-teal transition-colors">Accueil</a>
    <a href="/blog" class="block py-2 text-dark/70 hover:text-teal transition-colors">Blog</a>
    <a href="/blog/adoucisseur-deau-un-confort-discret-qui-change-tout" class="btn-primary mt-2 justify-center">Guide débutant</a>
    <a
      href="https://aqua2000.fr/estimer-votre-besoin?utm_source=blog&utm_medium=https://www.adoucisseur-eau.fr/&utm_campaign=backlinks"
      target="_blank"
      rel="noopener noreferrer"
      class="mt-2 px-5 py-2.5 rounded-full font-semibold text-sm bg-terracotta text-white text-center hover:opacity-90 transition-opacity"
    >
      Devis gratuit
    </a>
  </nav>
</header>

<style>
  /* Solid header (default) */
  #site-header .logo-primary { color: #0D5E77; }
  #site-header .nav-link { color: rgba(10, 30, 44, 0.65); }
  #site-header .nav-link:hover { color: #0D5E77; }
  #site-header .nav-active { color: #0D5E77; font-weight: 700; }
  #site-header .menu-icon { color: #0A1E2C; }

  /* Transparent hero (homepage only) */
  #site-header[data-transparent="true"]:not(.scrolled) .logo-primary { color: #F5FBFD; }
  #site-header[data-transparent="true"]:not(.scrolled) .nav-link { color: rgba(245, 251, 253, 0.80); }
  #site-header[data-transparent="true"]:not(.scrolled) .nav-link:hover { color: #F5FBFD; }
  #site-header[data-transparent="true"]:not(.scrolled) .nav-active { color: #F5FBFD; }
  #site-header[data-transparent="true"]:not(.scrolled) .menu-icon { color: #F5FBFD; }
</style>

<script>
  const btn = document.getElementById('menu-btn');
  const nav = document.getElementById('mobile-nav');
  const iconMenu = document.getElementById('icon-menu');
  const iconClose = document.getElementById('icon-close');

  btn?.addEventListener('click', () => {
    const isOpen = !nav?.classList.contains('hidden');
    nav?.classList.toggle('hidden', isOpen);
    nav?.classList.toggle('flex', !isOpen);
    iconMenu?.classList.toggle('hidden', !isOpen);
    iconClose?.classList.toggle('hidden', isOpen);
    btn.setAttribute('aria-expanded', String(!isOpen));
  });

  const header = document.getElementById('site-header');
  const updateHeader = () => {
    if (!header) return;
    if (window.scrollY > 60) {
      header.classList.add('scrolled', 'bg-cream/90', 'backdrop-blur-sm', 'border-b', 'border-beige', 'shadow-sm');
      header.classList.remove('bg-transparent');
    } else if (header.dataset.transparent === 'true') {
      header.classList.remove('scrolled', 'bg-cream/90', 'backdrop-blur-sm', 'border-b', 'border-beige', 'shadow-sm');
      header.classList.add('bg-transparent');
    }
  };
  window.addEventListener('scroll', updateHeader);
  updateHeader();
</script>
