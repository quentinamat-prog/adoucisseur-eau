---
import Icon from './Icon.astro';
---

<section class="relative min-h-screen bg-teal overflow-hidden flex items-center">
  <!-- Background decorative wave -->
  <div class="absolute bottom-0 left-0 right-0 h-32 md:h-48">
    <svg viewBox="0 0 1440 120" fill="none" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none" class="w-full h-full">
      <path d="M0 0C360 80 1080 80 1440 0V120H0V0Z" fill="#FDF8F5" />
    </svg>
  </div>

  <!-- Decorative glows -->
  <div class="absolute top-0 right-0 w-[40rem] h-[40rem] rounded-full bg-sage/10 blur-[120px] -translate-y-1/2 translate-x-1/4 pointer-events-none" aria-hidden="true"></div>
  <div class="absolute bottom-20 left-0 w-[32rem] h-[32rem] rounded-full bg-terracotta/15 blur-[100px] pointer-events-none" aria-hidden="true"></div>

  <!-- Organic curves -->
  <svg
    class="absolute inset-0 w-full h-full pointer-events-none"
    viewBox="0 0 1440 700"
    preserveAspectRatio="xMidYMid slice"
    fill="none"
    xmlns="http://www.w3.org/2000/svg"
    aria-hidden="true"
  >
    <!-- Top-right flowing arcs -->
    <path d="M 1560 -40 C 1300 80, 1100 -20, 900 120 C 700 260, 820 400, 640 380"
      stroke="#FDF8F5" stroke-width="1.5" stroke-opacity="0.10" />
    <path d="M 1560 20 C 1300 140, 1100 40, 900 180 C 700 320, 820 460, 640 440"
      stroke="#FDF8F5" stroke-width="1" stroke-opacity="0.07" />
    <path d="M 1560 80 C 1300 200, 1100 100, 900 240 C 700 380, 820 520, 640 500"
      stroke="#FDF8F5" stroke-width="0.75" stroke-opacity="0.05" />

    <!-- Bottom-left counter arcs -->
    <path d="M -120 700 C 100 560, 300 680, 520 560 C 740 440, 620 280, 840 300"
      stroke="#F0E8D9" stroke-width="1.25" stroke-opacity="0.09" />
    <path d="M -120 760 C 100 620, 300 740, 520 620 C 740 500, 620 340, 840 360"
      stroke="#F0E8D9" stroke-width="0.75" stroke-opacity="0.06" />

    <!-- Central S-curve -->
    <path d="M 200 700 C 260 540, 140 400, 320 300 C 500 200, 640 340, 580 480 C 520 620, 700 660, 820 560"
      stroke="#A9B199" stroke-width="1" stroke-opacity="0.12" />

    <!-- Accent ring — top left -->
    <circle cx="120" cy="120" r="80"  stroke="#FDF8F5" stroke-width="1"    stroke-opacity="0.06" />
    <circle cx="120" cy="120" r="140" stroke="#FDF8F5" stroke-width="0.75" stroke-opacity="0.04" />

    <!-- Accent ring — bottom right -->
    <circle cx="1360" cy="580" r="100" stroke="#F0E8D9" stroke-width="1"    stroke-opacity="0.07" />
    <circle cx="1360" cy="580" r="160" stroke="#F0E8D9" stroke-width="0.75" stroke-opacity="0.05" />
  </svg>

  <div class="relative max-w-6xl mx-auto px-4 sm:px-6 pt-28 pb-36 md:pb-44 grid lg:grid-cols-2 gap-10 lg:gap-12 items-center">
    <!-- Text side -->
    <div class="text-center lg:text-left">
      <span class="tag tag-light mb-6">Cuisine à domicile</span>

      <h1 class="font-display text-3xl sm:text-4xl md:text-5xl lg:text-6xl text-cream leading-tight mb-5 mt-2">
        Votre chef privé,<br />
        <span class="font-script text-beige text-4xl sm:text-5xl md:text-6xl lg:text-7xl">à domicile</span>
      </h1>

      <p class="font-body text-cream/80 text-base md:text-lg leading-relaxed mb-8 max-w-lg mx-auto lg:mx-0">
        Gustichef connecte particuliers et chefs privés pour des expériences culinaires sur mesure.
        Découvrez des talents, réservez en quelques clics et savourez l'instant.
      </p>

      <!-- App store CTAs -->
      <div class="flex flex-wrap gap-3 justify-center lg:justify-start">
        <a
          href="#download"
          class="inline-flex items-center gap-3 bg-dark text-cream px-5 py-3 rounded-xl font-body transition-all hover:bg-dark/80 hover:scale-105"
          aria-label="Télécharger sur l'App Store"
        >
          <svg class="w-7 h-7 fill-cream" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
            <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/>
          </svg>
          <div class="text-left leading-tight">
            <div class="text-xs text-cream/70">Disponible sur</div>
            <div class="text-sm font-semibold">App Store</div>
          </div>
        </a>

        <a
          href="#download"
          class="inline-flex items-center gap-3 bg-dark text-cream px-5 py-3 rounded-xl font-body transition-all hover:bg-dark/80 hover:scale-105"
          aria-label="Télécharger sur Google Play"
        >
          <svg class="w-7 h-7" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
            <path fill="#00C4FF" d="M3.5 1.8L13.5 12 3.5 22.2C3.2 22 3 21.6 3 21.2V2.8c0-.4.2-.8.5-1z"/>
            <path fill="#FFBC00" d="M17.5 8.5l2.3 1.3L17.5 12l2.3 2.2-2.3 1.3-4-3.5z"/>
            <path fill="#F44336" d="M13.5 12l4 3.5-10.3 5.9c-.3.2-.7.2-1 0L13.5 12z"/>
            <path fill="#4CAF50" d="M13.5 12L6.2 2.6c.3-.2.7-.2 1 0l10.3 5.9-4 3.5z"/>
          </svg>
          <div class="text-left leading-tight">
            <div class="text-xs text-cream/70">Disponible sur</div>
            <div class="text-sm font-semibold">Google Play</div>
          </div>
        </a>
      </div>

      <!-- Social proof -->
      <div class="flex items-center gap-4 mt-8 justify-center lg:justify-start">
        <div class="flex -space-x-2">
          {[...Array(4)].map((_, i) => (
            <div class={`w-9 h-9 rounded-full border-2 border-teal flex items-center justify-center text-xs font-bold text-white ${['bg-terracotta','bg-sage','bg-beige','bg-dark'][i]}`}>
              {['A','B','C','D'][i]}
            </div>
          ))}
        </div>
        <p class="font-body text-cream/80 text-sm">
          <strong class="text-cream">+500 chefs</strong> déjà inscrits
        </p>
      </div>
    </div>

    <!-- App mockup side — hidden on mobile, visible md+ -->
    <div class="hidden md:flex relative justify-center lg:justify-end">
      <div class="relative w-56 md:w-64 lg:w-72">
        <!-- Phone frame -->
        <div class="bg-dark rounded-[3rem] p-3 shadow-2xl shadow-dark/50">
          <div class="bg-cream rounded-[2.5rem] overflow-hidden aspect-[9/19.5]">
            <!-- Mockup screen content -->
            <div class="bg-teal h-16 flex items-end px-5 pb-3">
              <span class="font-display text-cream text-lg">Gusti<span class="text-terracotta">chef</span></span>
            </div>
            <div class="p-4 space-y-3">
              <div class="bg-beige rounded-2xl p-3">
                <div class="w-full h-28 bg-sage/30 rounded-xl mb-2 flex items-center justify-center text-teal">
                  <Icon name="chef-hat" size={48} strokeWidth={1.5} />
                </div>
                <div class="font-body text-xs font-bold text-dark">Chef Marco D.</div>
                <div class="font-body text-xs text-dark/60">Cuisine italienne · Paris</div>
                <div class="flex items-center gap-0.5 mt-1 text-terracotta">
                  {[...Array(5)].map(() => <Icon name="star" size={12} strokeWidth={1.5} fill />)}
                  <span class="font-body text-xs text-dark/50 ml-1">(48)</span>
                </div>
              </div>
              <div class="bg-beige rounded-2xl p-3">
                <div class="w-full h-20 bg-terracotta/15 rounded-xl mb-2 flex items-center justify-center text-terracotta">
                  <Icon name="sushi" size={40} strokeWidth={1.5} />
                </div>
                <div class="font-body text-xs font-bold text-dark">Chef Yuki S.</div>
                <div class="font-body text-xs text-dark/60">Cuisine japonaise · Lyon</div>
              </div>
            </div>
          </div>
        </div>

        <!-- Floating badge -->
        <div class="absolute -top-4 -right-4 bg-terracotta text-cream rounded-2xl px-4 py-2 shadow-lg">
          <div class="font-body text-xs font-bold">Nouveau !</div>
          <div class="font-body text-xs opacity-80">500+ chefs</div>
        </div>

        <!-- Floating notification -->
        <div class="absolute -bottom-4 -left-6 bg-cream rounded-2xl px-4 py-2 shadow-lg border border-beige flex items-center gap-2">
          <div class="w-8 h-8 rounded-full bg-sage/30 flex items-center justify-center text-teal">
            <Icon name="check" size={16} strokeWidth={2.5} />
          </div>
          <div>
            <div class="font-body text-xs font-bold text-dark">Réservation confirmée</div>
            <div class="font-body text-xs text-dark/50">Dîner ce vendredi</div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
