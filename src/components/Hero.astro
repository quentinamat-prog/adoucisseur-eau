---
---

<section class="relative bg-teal overflow-hidden">
  <!-- Vague décorative en bas -->
  <div class="absolute bottom-0 left-0 right-0 h-20 md:h-32">
    <svg viewBox="0 0 1440 80" fill="none" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none" class="w-full h-full">
      <path d="M0 0C360 60 1080 60 1440 0V80H0V0Z" fill="#F5FBFD" />
    </svg>
  </div>

  <!-- Glow décoratifs -->
  <div class="absolute top-0 right-0 w-[36rem] h-[36rem] rounded-full bg-white/5 blur-[120px] -translate-y-1/3 translate-x-1/4 pointer-events-none" aria-hidden="true"></div>
  <div class="absolute bottom-10 left-0 w-[28rem] h-[28rem] rounded-full bg-terracotta/10 blur-[100px] pointer-events-none" aria-hidden="true"></div>

  <!-- SVG vagues de fond -->
  <svg class="absolute inset-0 w-full h-full pointer-events-none" viewBox="0 0 1440 600" preserveAspectRatio="xMidYMid slice" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
    <path d="M0 300 C 200 200, 400 400, 600 300 C 800 200, 1000 400, 1200 300 C 1300 250, 1380 280, 1440 260" stroke="white" stroke-width="1" stroke-opacity="0.06"/>
    <path d="M0 350 C 200 250, 400 450, 600 350 C 800 250, 1000 450, 1200 350 C 1300 300, 1380 330, 1440 310" stroke="white" stroke-width="0.75" stroke-opacity="0.04"/>
    <circle cx="100" cy="100" r="80" stroke="white" stroke-width="1" stroke-opacity="0.05"/>
    <circle cx="1340" cy="500" r="110" stroke="white" stroke-width="1" stroke-opacity="0.05"/>
  </svg>

  <div class="relative max-w-4xl mx-auto px-4 sm:px-6 pt-32 pb-40 md:pb-48 text-center">
    <span class="tag tag-outline-light mb-6">Guide & Conseils</span>

    <h1 class="font-display font-bold text-3xl sm:text-4xl md:text-5xl lg:text-6xl text-cream leading-tight mb-6 mt-3">
      Tout savoir sur<br />
      <span class="text-terracotta">les adoucisseurs d'eau</span>
    </h1>

    <p class="font-body text-cream/80 text-base md:text-lg leading-relaxed mb-10 max-w-2xl mx-auto">
      Guides d'achat, conseils d'installation, entretien et comparatifs — tout ce qu'il faut pour choisir et profiter d'une eau douce chez vous.
    </p>

    <div class="flex flex-wrap gap-4 justify-center">
      <a href="/blog" class="btn-primary">
        Lire les articles
      </a>
      <a href="/blog/adoucisseur-deau-un-confort-discret-qui-change-tout" class="btn-outline">
        Commencer par les bases
      </a>
    </div>

    <!-- Stats -->
    <div class="flex flex-wrap justify-center gap-8 mt-14">
      {[
        { value: '100%', label: 'Gratuit' },
        { value: 'Guides', label: 'Complets & à jour' },
        { value: 'Sans pub', label: 'Contenu indépendant' },
      ].map(({ value, label }) => (
        <div class="text-center">
          <div class="font-display font-bold text-2xl text-cream">{value}</div>
          <div class="font-body text-xs text-cream/60 mt-1">{label}</div>
        </div>
      ))}
    </div>
  </div>
</section>
