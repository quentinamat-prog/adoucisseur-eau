---
import type { CollectionEntry } from 'astro:content';
import Icon from './Icon.astro';

interface Props {
  posts: CollectionEntry<'blog'>[];
}
const { posts } = Astro.props;

const formatDate = (date: Date) =>
  new Intl.DateTimeFormat('fr-FR', { year: 'numeric', month: 'long', day: 'numeric' }).format(date);
---

<section id="blog" class="py-24 bg-cream">
  <div class="max-w-6xl mx-auto px-6">
    <div class="flex items-end justify-between mb-12">
      <div>
        <span class="tag tag-beige mb-4">Le blog</span>
        <h2 class="section-title mt-4">
          Conseils & inspirations<br />
          <span class="text-terracotta">culinaires</span>
        </h2>
      </div>
      <a href="/blog" class="hidden md:inline-flex items-center gap-2 font-body text-sm font-semibold text-teal hover:text-terracotta transition-colors">
        Voir tous les articles →
      </a>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
      {posts.map((post) => (
        <article class="group bg-white rounded-3xl overflow-hidden shadow-sm hover:shadow-md transition-all duration-200 hover:-translate-y-1">
          <!-- Image or placeholder -->
          <div class="aspect-video bg-beige flex items-center justify-center relative overflow-hidden">
            {post.data.image
              ? <img src={post.data.image} alt={post.data.imageAlt ?? post.data.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" width="800" height="450" loading="lazy" sizes="(max-width: 768px) calc(100vw - 32px), (max-width: 1024px) calc(50vw - 48px), 380px" />
              : <div class="text-terracotta/40"><Icon name="fork-knife" size={64} strokeWidth={1.25} /></div>
            }
            <div class="absolute top-3 left-3">
              <span class="tag tag-teal">{post.data.category}</span>
            </div>
            {post.data.featured && (
              <div class="absolute top-3 right-3">
                <span class="tag tag-terracotta">À la une</span>
              </div>
            )}
          </div>

          <div class="p-6">
            <time datetime={post.data.pubDate.toISOString()} class="font-body text-xs text-dark/50 mb-3 block">
              {formatDate(post.data.pubDate)}
            </time>
            <h3 class="font-display text-lg text-dark mb-2 leading-snug group-hover:text-teal transition-colors">
              <a href={`/blog/${post.slug}`} class="stretched-link">
                {post.data.title}
              </a>
            </h3>
            <p class="font-body text-sm text-dark/60 leading-relaxed line-clamp-3">
              {post.data.description}
            </p>
            <div class="flex items-center gap-2 mt-4 pt-4 border-t border-beige">
              <div class="w-7 h-7 rounded-full bg-teal flex items-center justify-center text-xs font-bold text-cream flex-shrink-0">
                {post.data.author.charAt(0)}
              </div>
              <span class="font-body text-xs text-dark/60">{post.data.author}</span>
            </div>
          </div>
        </article>
      ))}
    </div>

    <div class="text-center mt-10 md:hidden">
      <a href="/blog" class="btn-primary">Voir tous les articles</a>
    </div>
  </div>
</section>
